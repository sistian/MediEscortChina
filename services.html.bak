          <a href="#" class="whatsapp-float" aria-label="Contact MediEscortChina on WhatsApp for medical tourism consultation" data-action="open-qr" data-qr-type="whatsapp" aria-label="Chat on WhatsApp"><img loading="lazy" src="images/whatsapp-icon.png" alt="WhatsApp"></a>
            <script src="js/main.js"></script>
            <script>
// Exchange rate (USD to CNY) - will be updated from API
let usdToCnyRate = 7.2;

// Fetch live exchange rate
async function fetchExchangeRate() {
  try {
    const res = await fetch('https://api.exchangerate-api.com/v4/latest/USD');
    const data = await res.json();
    if (data && data.rates && data.rates.CNY) {
      usdToCnyRate = data.rates.CNY;
      updateAllPriceDisplays();
    }
  } catch (e) {
    console.log('Rate fetch failed, using fallback:', usdToCnyRate);
  }
}
fetchExchangeRate();

function formatCny(usd) {
  const cny = Math.round(usd * usdToCnyRate);
  return '≈ ¥' + cny.toLocaleString();
}

function updateAllPriceDisplays() {
  // Appointment booking is always $15
  const apptPriceUsd = document.getElementById('appt-price-usd');
  const apptPriceCny = document.getElementById('appt-price-cny');
  if (apptPriceUsd) apptPriceUsd.textContent = '$15.00 USD';
  if (apptPriceCny) apptPriceCny.textContent = formatCny(15);
  // Escort price
  calculateEscortPrice();
}

// Escort pricing
const ESCORT_PRICES = {
  basic:   { tier2: 92, tier1: 136 },
  premium: { tier2: 157, tier1: 231 },
  expert:  { tier2: 230, tier1: 340 }
};

// Email validation regex
function isValidEmail(email) {
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
}

// Phone validation - allows digits, spaces, +, -, (), minimum 7 digits
function isValidPhone(phone) {
  const digitsOnly = phone.replace(/\D/g, '');
  return digitsOnly.length >= 7 && /^[\d\s+\-()]+$/.test(phone);
}

// Date validation: start date must be <= end date
function validateEscortDates() {
  const startDateInput = document.getElementById('escort-start-date');
  const endDateInput = document.getElementById('escort-end-date');
  if (!startDateInput || !endDateInput) return true;

  const startDate = startDateInput.value;
  const endDate = endDateInput.value;

  // Only validate if both dates are filled
  if (startDate && endDate) {
    if (new Date(startDate) > new Date(endDate)) {
      alert('Trip end date must be on or after the start date. Please correct your dates.');
      endDateInput.focus();
      return false;
    }
  }
  return true;
}

// Auto-set minimum end date when start date changes
document.addEventListener('DOMContentLoaded', function() {
  const startDateInput = document.getElementById('escort-start-date');
  const endDateInput = document.getElementById('escort-end-date');
  if (startDateInput && endDateInput) {
    startDateInput.addEventListener('change', function() {
      endDateInput.min = startDateInput.value;
    });
  }
});

// City to tier mapping
const CITY_TIER_MAP = {
  beijing: 'tier1', shanghai: 'tier1', guangzhou: 'tier1', shenzhen: 'tier1',
  wuhan: 'tier2', hangzhou: 'tier2', chengdu: 'tier2', chongqing: 'tier2'
};

function calculateEscortPrice() {
  const tier = document.getElementById('escort-tier').value;
  const city = document.getElementById('escort-city').value;
  const days = parseInt(document.getElementById('escort-days').value) || 1;

  const escortPriceUsd = document.getElementById('escort-price-usd');
  const escortPriceCny = document.getElementById('escort-price-cny');

  if (!tier || !city) {
    if (escortPriceUsd) escortPriceUsd.textContent = '$0.00 USD';
    if (escortPriceCny) escortPriceCny.textContent = formatCny(0);
    return 0;
  }

  const cityTier = CITY_TIER_MAP[city];
  if (!cityTier) {
    if (escortPriceUsd) escortPriceUsd.textContent = '$0.00 USD';
    if (escortPriceCny) escortPriceCny.textContent = formatCny(0);
    return 0;
  }

  const dailyRate = ESCORT_PRICES[tier][cityTier];
  const total = dailyRate * days;

  if (escortPriceUsd) escortPriceUsd.textContent = '$' + total.toLocaleString() + '.00 USD';
  if (escortPriceCny) escortPriceCny.textContent = formatCny(total);
  return total;
}

// Email Notification Setup
// FormSubmit email notification — submits via hidden iframe to avoid CORS/bot issues
function sendBookingNotification(serviceType, priceUSD) {
  const formId = serviceType === 'appt' ? 'apptForm' : 'escortForm';
  const form = document.getElementById(formId);
  if (!form) return;

  const now = new Date().toLocaleString('en-US', { timeZone: 'Asia/Shanghai' });
  const email = (form.querySelector('[name=email]') || {}).value || 'noreply@mediescortchina.com';
  
  // Build FormData from the form
  const formData = new FormData(form);
  
  // Add formsubmit configuration fields
  formData.append('_subject', '[MediEscortChina] New ' + (serviceType === 'appt' ? 'Appointment' : 'Escort') + ' Booking - $' + priceUSD + ' USD');
  formData.append('_replyto', email);
  formData.append('_template', 'table');
  formData.append('_captcha', 'false');
  formData.append('service_type', serviceType === 'appt' ? 'Online Appointment Booking' : 'Escort & Translation');
  formData.append('price_usd', '$' + priceUSD);
  formData.append('form_source', 'services.html');
  formData.append('booking_time', now);

  // Try AJAX submission first for reliable delivery
  if (typeof fetch !== 'undefined') {
    fetch('https://formsubmit.co/ajax/sistian@qq.com', {
      method: 'POST',
      headers: { 'Accept': 'application/json' },
      body: formData
    })
    .then(response => {
      if (response.ok) {
        console.log('✅ Booking form submitted successfully to sistian@qq.com');
      } else {
        console.error('❌ Form submission failed:', response.status);
        iframeFallback(form, serviceType, priceUSD, email, now);
      }
    })
    .catch(error => {
      console.error('❌ Form submission error:', error);
      iframeFallback(form, serviceType, priceUSD, email, now);
    });
  } else {
    iframeFallback(form, serviceType, priceUSD, email, now);
  }
  
  // Fallback: iframe-based form submission
  function iframeFallback(form, serviceType, priceUSD, email, now) {
    const originalAction = form.action || '';
    const originalTarget = form.target || '';
    const originalMethod = form.method || 'GET';
    
    form.action = 'https://formsubmit.co/sistian@qq.com';
    form.method = 'POST';
    form.target = 'hiddenFormSubmit';
    
    form.querySelectorAll('input[type="hidden"]').forEach(f => f.remove());
    
    function setHidden(name, value) {
      const el = document.createElement('input');
      el.type = 'hidden';
      el.name = name;
      el.value = value;
      form.appendChild(el);
    }
    
    setHidden('_subject', '[MediEscortChina] New ' + (serviceType === 'appt' ? 'Appointment' : 'Escort') + ' Booking - $' + priceUSD + ' USD');
    setHidden('_replyto', email);
    setHidden('_template', 'table');
    setHidden('_captcha', 'false');
    setHidden('service_type', serviceType === 'appt' ? 'Online Appointment Booking' : 'Escort & Translation');
    setHidden('price_usd', '$' + priceUSD);
    setHidden('form_source', 'services.html');
    setHidden('booking_time', now);
    
    try {
      form.submit();
      console.log('📧 Form submitted via iframe fallback');
    } catch (e) {
      console.error('Failed to submit form:', e);
    }
    
    setTimeout(function() {
      form.action = originalAction;
      form.target = originalTarget;
      form.method = originalMethod;
    }, 1000);
  }
}

// Payment Modal
let currentService = '';
let currentPriceUSD = 0;

function showPaymentModal(service) {
  currentService = service;

  if (service === 'appt') {
    const fields = ['appt-firstname','appt-lastname','appt-passport','appt-dob','appt-nationality','appt-date','appt-condition','appt-email','appt-phone'];
    for (const id of fields) {
      const el = document.getElementById(id);
      if (!el || !el.value.trim()) {
        alert('Please fill in all required fields.');
        if (el) el.focus();
        return;
      }
    }
    // Validate email format
    const apptEmail = document.getElementById('appt-email').value.trim();
    if (!isValidEmail(apptEmail)) {
      alert('Please enter a valid email address (e.g., name@example.com).');
      document.getElementById('appt-email').focus();
      return;
    }
    // Validate phone format
    const apptPhone = document.getElementById('appt-phone').value.trim();
    if (!isValidPhone(apptPhone)) {
      alert('Please enter a valid phone number (at least 7 digits).');
      document.getElementById('appt-phone').focus();
      return;
    }
    currentPriceUSD = 15;
    const modalTitle = document.getElementById('modal-title');
    if (modalTitle) modalTitle.textContent = 'Appointment Booking Payment';
  } else if (service === 'escort') {
    const fields = ['escort-tier','escort-city','escort-days','escort-start-date','escort-end-date','escort-firstname','escort-lastname','escort-passport','escort-dob','escort-nationality','escort-email','escort-phone','escort-condition'];
    for (const id of fields) {
      const el = document.getElementById(id);
      if (!el || !el.value.trim()) {
        alert('Please fill in all required fields.');
        if (el) el.focus();
        return;
      }
    }
    // Validate date range
    if (!validateEscortDates()) return;
    // Validate email format
    const escortEmail = document.getElementById('escort-email').value.trim();
    if (!isValidEmail(escortEmail)) {
      alert('Please enter a valid email address (e.g., name@example.com).');
      document.getElementById('escort-email').focus();
      return;
    }
    // Validate phone format
    const escortPhone = document.getElementById('escort-phone').value.trim();
    if (!isValidPhone(escortPhone)) {
      alert('Please enter a valid phone number (at least 7 digits).');
      document.getElementById('escort-phone').focus();
      return;
    }
    currentPriceUSD = calculateEscortPrice();
    if (currentPriceUSD <= 0) {
      alert('Please select a tier and city to calculate price.');
      return;
    }
    const modalTitle = document.getElementById('modal-title');
    if (modalTitle) modalTitle.textContent = 'Escort Service Payment';
  }

  const modalPriceUsd = document.getElementById('modal-price-usd');
  const modalPriceCny = document.getElementById('modal-price-cny');
  if (modalPriceUsd) modalPriceUsd.textContent = '$' + currentPriceUSD.toLocaleString() + '.00 USD';
  if (modalPriceCny) modalPriceCny.textContent = formatCny(currentPriceUSD);

  const paymentModal = document.getElementById('paymentModal');
  if (paymentModal) paymentModal.classList.add('active');
  document.body.style.overflow = 'hidden';

  // Reset to step 1
  const step1 = document.getElementById('payment-step-1');
  const step2 = document.getElementById('payment-step-2');
  if (step1) step1.style.display = 'block';
  if (step2) step2.style.display = 'none';
  const btn = document.getElementById('confirmPaymentBtn');
  if (btn) {
    btn.disabled = false;
    btn.style.display = 'block';
    btn.innerHTML = '<span>I Have Paid — Confirm My Booking</span>';
  }

  // Switch to Alipay tab by default
  switchPaymentTab('alipay');
}

function closePaymentModal() {
  const paymentModal = document.getElementById('paymentModal');
  if (paymentModal) paymentModal.classList.remove('active');
  document.body.style.overflow = '';
  // Reset to step 1 for next time
  const step1 = document.getElementById('payment-step-1');
  const step2 = document.getElementById('payment-step-2');
  if (step1) step1.style.display = 'block';
  if (step2) step2.style.display = 'none';
  const btn = document.getElementById('confirmPaymentBtn');
  if (btn) {
    btn.disabled = false;
    btn.style.display = 'block';
    btn.innerHTML = '<span>I Have Paid — Confirm My Booking</span>';
  }
}

function switchPaymentTab(method) {
  document.querySelectorAll('.payment-tab').forEach(function(t) { t.classList.remove('active'); });
  const tab = document.getElementById('tab-' + method);
  if (tab) tab.classList.add('active');
  const qrAlipay = document.getElementById('qr-alipay');
  const qrPaypal = document.getElementById('qr-paypal');
  if (qrAlipay) qrAlipay.style.display = method === 'alipay' ? 'block' : 'none';
  if (qrPaypal) qrPaypal.style.display = method === 'paypal' ? 'block' : 'none';
}

// Customer confirms payment is done — submit form to email
function confirmPayment() {
  // Disable button to prevent double-click
  const btn = document.getElementById('confirmPaymentBtn');
  if (btn) {
    btn.disabled = true;
    btn.innerHTML = '<span>⏳ Processing...</span>';
  }

  // Submit the form data
  sendBookingNotification(currentService, currentPriceUSD);

  // Show success step (step-2), hide step-1
  const step1 = document.getElementById('payment-step-1');
  const step2 = document.getElementById('payment-step-2');
  if (step1) step1.style.display = 'none';
  if (step2) step2.style.display = 'block';

  // Scroll to top
  const modal = document.querySelector('.payment-modal');
  if (modal) modal.scrollTop = 0;
}

// Close modal on overlay click
document.addEventListener('click', function(e) {
  if (e.target && e.target.id === 'paymentModal') {
    closePaymentModal();
  }
});
            </script>
          
<!-- QR Code Modal -->
<div id="qrModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.7); z-index:9999; justify-content:center; align-items:center;" data-action="close-qr">
  <div style="background:white; border-radius:16px; padding:32px; max-width:360px; width:90%; text-align:center; position:relative; cursor:default;" data-action="stop-propagation">
    <button data-action="close-qr" style="position:absolute; top:12px; right:16px; background:none; border:none; font-size:24px; cursor:pointer; color:var(--gray-400);">&times;</button>
    <img loading="lazy" id="qrImage" src="" alt="QR Code" style="width:200px; height:200px; border-radius:12px; margin:16px auto; display:block;">
    <p id="qrMessage" style="font-size:14px; color:var(--gray-600); margin-top:16px; line-height:1.6;"></p>
    <div style="margin-top:20px;">
      <a id="qrLink" href="#" target="_blank" style="display:inline-block; padding:12px 24px; background:var(--coral); color:white; border-radius:8px; text-decoration:none; font-weight:600; font-size:14px;"></a>
    </div>
  </div>
</div>
<script>
function openQRModal(type) {
  const modal = document.getElementById('qrModal');
  const img = document.getElementById('qrImage');
  const msg = document.getElementById('qrMessage');
  const link = document.getElementById('qrLink');
  
  if (type === 'whatsapp') {
    img.src = 'images/whatsapp-qr.png';
    msg.innerHTML = '📱 Scan this QR code with WhatsApp to add us.<br><br>Or add us directly: <strong>+86-155-2777-1775</strong><br><br>After adding, feel free to send your inquiry anytime!';
    link.href = 'https://wa.me/8615527771775';
    link.textContent = 'Open WhatsApp Chat';
  } else if (type === 'wechat') {
    img.src = 'images/wechat-qr.png';
    msg.innerHTML = '💬 Scan this QR code with WeChat to add us.<br><br>After adding, feel free to send your inquiry anytime!';
    link.href = 'weixin://';
    link.textContent = 'Open WeChat';
  }
  
  modal.style.display = 'flex';
}
function closeQRModal() {
  document.getElementById('qrModal').style.display = 'none';
}
</script>
<style>
@keyframes bounce {
  0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
  40% { transform: translateY(-8px); }
  60% { transform: translateY(-4px); }
}
</style>
</body>
        </html>