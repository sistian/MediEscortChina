<style> .price-note { font-size:0.75rem; color:var(--gray-600); margin-top:4px; } .appt-highlight { border: 2px solid var(--coral); background: var(--coral-light); } /* Booking Form Styles */.booking-form { max-width:700px; margin:0 auto; } .booking-form .form-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:16px; } .booking-form .form-group { margin-bottom:16px; } .booking-form label { display:block; font-weight:600; margin-bottom:6px; color:var(--navy); font-size:0.9rem; } .booking-form input, .booking-form select, .booking-form textarea { width:100%; padding:12px 14px; border:1.5px solid #ddd; border-radius:10px; font-size:1rem; font-family:inherit; background:#fff; transition:border-color 0.2s; } .booking-form input:focus, .booking-form select:focus, .booking-form textarea:focus { outline:none; border-color:var(--coral); } .booking-form textarea { resize:vertical; min-height:80px; } .booking-form .price-display { background:linear-gradient(135deg, var(--coral-light), #fff); border:2px solid var(--coral); border-radius:12px; padding:20px; text-align:center; margin:20px 0; } .booking-form .price-display .price-usd { font-size:2rem; font-weight:800; color:var(--coral); } .booking-form .price-display .price-cny { font-size:1.1rem; color:var(--gray-600); margin-top:4px; } .booking-form .btn-submit { width:100%; padding:16px; font-size:1.1rem; font-weight:700; border:none; border-radius:10px; background:var(--coral); color:white; cursor:pointer; transition:opacity 0.2s; } .booking-form .btn-submit:hover { opacity:0.9; } .booking-form .privacy-note { font-size:0.8rem; color:var(--gray-600); margin-top:12px; padding:12px; background:#f8f9fa; border-radius:8px; } /* Payment Modal */.payment-modal-overlay { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.6); z-index:9999; justify-content:center; align-items:center; } .payment-modal-overlay.active { display:flex; } .payment-modal { background:white; border-radius:16px; padding:32px; max-width:480px; width:90%; max-height:90vh; overflow-y:auto; text-align:center; position:relative; } .payment-modal .close-btn { position:absolute; top:16px; right:20px; font-size:1.5rem; cursor:pointer; color:var(--gray-600); background:none; border:none; } .payment-modal h3 { margin-bottom:8px; color:var(--navy); } .payment-modal .payment-tabs { display:flex; gap:8px; justify-content:center; margin:20px 0; } .payment-modal .payment-tab { padding:10px 24px; border:2px solid #ddd; border-radius:8px; cursor:pointer; font-weight:600; background:white; } .payment-modal .payment-tab.active { border-color:var(--coral); background:var(--coral-light); color:var(--navy); } .payment-modal .qr-code { max-width:260px; margin:16px auto; border-radius:12px; } .payment-modal .qr-code img { width:100%; border-radius:12px; } .payment-modal .contact-info { background:#f0f9f0; border-radius:12px; padding:20px; margin-top:20px; text-align:left; } .payment-modal .contact-info h4 { color:var(--navy); margin-bottom:12px; } .payment-modal .contact-info p { margin:6px 0; font-size:0.95rem; } .payment-modal .screenshot-note { background:#fff8e1; border-left:4px solid #ffc107; padding:12px 16px; margin:16px 0; text-align:left; font-size:0.9rem; } @media (max-width: 1024px) { .booking-form { max-width: 100%; padding: 0 20px; } .payment-modal { padding: 24px; max-width: 440px; } } @media (max-width: 768px) { .booking-form .form-row { grid-template-columns: 1fr; } .booking-form { padding: 0 16px; } .payment-modal { padding: 20px; max-width: 90vw; } .payment-modal .payment-tabs { flex-wrap: wrap; } .payment-modal .payment-tab { padding: 8px 16px; font-size: 0.85rem; } .payment-modal .qr-code { max-width: 200px; } } @media (max-width: 480px) { .booking-form .price-display .price-usd { font-size: 1.6rem; } .booking-form .btn-submit { padding: 14px; font-size: 1rem; } .payment-modal { padding: 16px; } .payment-modal h3 { font-size: 1.1rem; } .payment-modal .contact-info { padding: 16px; } .payment-modal .contact-info p { font-size: 0.85rem; } } </style>
