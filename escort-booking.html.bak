    <a href="#" class="whatsapp-float" aria-label="Contact MediEscortChina on WhatsApp for medical tourism consultation" data-action="open-qr" data-qr-type="whatsapp" aria-label="Chat on WhatsApp"><img loading="lazy" src="images/whatsapp-icon.png" alt="WhatsApp"></a>
    <script src="js/main.js"></script>
    <script> //Pricing data const prices = { basic: { t1: 500, t2: 400, t3: 300 }, premium: { t1: 1000, t2: 800, t3: 600 }, expert: { t1: 2000, t2: 1500, t3: 1000 } }; const tier1 = ['beijing','shanghai','guangzhou','shenzhen']; const tier2 = ['hangzhou','wuhan','chongqing','chengdu']; const durationMultipliers = { half: 0.6, full: 1, multi2: 1.9, multi3: 2.7, multi5: 4.5, custom: 1 }; const addonPrices = { translate: 100, pickup: 100, pharmacy: 50, report: 100 }; const exchangeRate = 7.2; function getCityTier(city) { if (tier1.includes(city)) return 't1'; if (tier2.includes(city)) return 't2'; return 't3'; } function selectEscort(type, el) { document.querySelectorAll('.escort-option').forEach(o => o.classList.remove('selected')); el.classList.add('selected'); el.querySelector('input').checked = true; calculateTotal(); } function calculateTotal() { const type = document.querySelector('input[name="escortType"]:checked')?.value; const city = document.getElementById('escortCity').value; const duration = document.getElementById('escortDuration').value; if (!type || !city) { document.getElementById('totalRMB').textContent = '¥0'; document.getElementById('totalUSD').textContent = '≈ $0 USD'; return; } const tier = getCityTier(city); let basePrice = prices[type][tier]; let total = basePrice * durationMultipliers[duration]; if (duration.startsWith('multi')) { const days = parseInt(duration.replace('multi','')); total = basePrice * days * 0.9; } document.querySelectorAll('input[name="addon"]:checked').forEach(cb => { total += addonPrices[cb.value] || 0; }); const usd = Math.round(total /exchangeRate); document.getElementById('totalRMB').textContent = '¥' + total.toLocaleString(); document.getElementById('totalUSD').textContent = '≈ $' + usd.toLocaleString() + ' USD'; document.getElementById('priceBasic').textContent = 'From ¥' + prices.basic[tier]; document.getElementById('pricePremium').textContent = 'From ¥' + prices.premium[tier]; document.getElementById('priceExpert').textContent = 'From ¥' + prices.expert[tier]; } function closeModal() { document.getElementById('bookingModal').classList.remove('active'); } const tomorrow = new Date(); tomorrow.setDate(tomorrow.getDate() + 1); document.getElementById('escortDate').value = tomorrow.toISOString().split('T')[0]; document.getElementById('escortForm').addEventListener('submit', function(e) { e.preventDefault(); const type = document.querySelector('input[name="escortType"]:checked')?.value; const city = document.getElementById('escortCity').value; if (!type || !city) { alert('Please select escort type and city'); return; } const formData = { name: document.getElementById('patientName').value, email: document.getElementById('patientEmail').value, phone: document.getElementById('patientPhone').value, age: document.getElementById('patientAge').value, nationality: document.getElementById('patientNationality').value, city: city, date: document.getElementById('escortDate').value, time: document.getElementById('escortTime').value, duration: document.getElementById('escortDuration').value, hospital: document.getElementById('hospitalName').value, department: document.getElementById('department').value, special: document.getElementById('specialRequests').value }; const tier = getCityTier(city); let basePrice = prices[type][tier]; let total = basePrice * durationMultipliers[formData.duration]; if (formData.duration.startsWith('multi')) { const days = parseInt(formData.duration.replace('multi','')); total = basePrice * days * 0.9; } let addonText = []; let addonTotal = 0; document.querySelectorAll('input[name="addon"]:checked').forEach(cb => { addonText.push(cb.value + ' (+¥' + addonPrices[cb.value] + ')'); addonTotal += addonPrices[cb.value]; }); total += addonTotal; const usd = Math.round(total /exchangeRate); const summaryHTML = `
      <div style="border:1px solid var(--gray-100);border-radius:var(--radius);padding:16px;margin-bottom:16px;">
        <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--gray-100);"><span style="color:var(--gray-600);font-size:0.9rem;">Escort Type</span><span style="font-weight:600;color:var(--navy);font-size:0.9rem;">${type.charAt(0).toUpperCase()+type.slice(1)}</span></div>
        <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--gray-100);"><span style="color:var(--gray-600);font-size:0.9rem;">City</span><span style="font-weight:600;color:var(--navy);font-size:0.9rem;">${formData.city.charAt(0).toUpperCase()+formData.city.slice(1)}</span></div>
        <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--gray-100);"><span style="color:var(--gray-600);font-size:0.9rem;">Date</span><span style="font-weight:600;color:var(--navy);font-size:0.9rem;">${formData.date}</span></div>
        <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--gray-100);"><span style="color:var(--gray-600);font-size:0.9rem;">Duration</span><span style="font-weight:600;color:var(--navy);font-size:0.9rem;">${formData.duration}</span></div>
        <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--gray-100);"><span style="color:var(--gray-600);font-size:0.9rem;">Patient</span><span style="font-weight:600;color:var(--navy);font-size:0.9rem;">${formData.name}</span></div>
        <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--gray-100);"><span style="color:var(--gray-600);font-size:0.9rem;">Contact</span><span style="font-weight:600;color:var(--navy);font-size:0.9rem;">${formData.email}</span></div>
        ${addonText.length > 0 ? `
        <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--gray-100);"><span style="color:var(--gray-600);font-size:0.9rem;">Add-ons</span><span style="font-weight:600;color:var(--navy);font-size:0.9rem;">${addonText.join(', ')}</span></div>
        ` : ''} </div>
        `; document.getElementById('bookingSummary').innerHTML = summaryHTML; document.getElementById('modalRMB').textContent = '¥' + total.toLocaleString(); document.getElementById('modalUSD').textContent = '≈ $' + usd.toLocaleString() + ' USD'; document.getElementById('bookingModal').classList.add('active'); }); document.getElementById('confirmSubmit').addEventListener('click', function() { document.getElementById('escortForm').submit(); });
//Close modal on background click document.getElementById('bookingModal').addEventListener('click', function(e) { if (e.target === this) closeModal(); }); </script>
      
<script>
// WhatsApp Form Submission Helper
function sendViaWhatsApp(formId, messageTemplate) {
  const form = document.getElementById(formId);
  if (!form) return;
  
  const formData = new FormData(form);
  const data = Object.fromEntries(formData.entries());
  
  // Remove hidden fields from display
  const hiddenFields = ['_next', '_subject', '_template', '_captcha', '_replyto', '_cc', '_honey'];
  hiddenFields.forEach(f => delete data[f]);
  
  let message = messageTemplate;
  
  // Build message from form data
  const entries = Object.entries(data).filter(([k,v]) => v && v.trim());
  if (entries.length > 0) {
    message += '\n\n';
    entries.forEach(([key, val]) => {
      // Capitalize and clean key
      const label = key.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
      message += `*${label}:* ${val}\n`;
    });
  }
  
  const encoded = encodeURIComponent(message);
  window.open(`https://wa.me/8615527771775?text=${encoded}`, '_blank');
}
</script>

<!-- QR Code Modal -->
<div id="qrModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.7); z-index:9999; justify-content:center; align-items:center;" data-action="close-qr">
  <div style="background:white; border-radius:16px; padding:32px; max-width:360px; width:90%; text-align:center; position:relative; cursor:default;" data-action="stop-propagation">
    <button data-action="close-qr" style="position:absolute; top:12px; right:16px; background:none; border:none; font-size:24px; cursor:pointer; color:var(--gray-400);">&times;</button>
    <img loading="lazy" id="qrImage" src="" alt="QR Code" style="width:200px; height:200px; border-radius:12px; margin:16px auto; display:block;">
    <p id="qrMessage" style="font-size:14px; color:var(--gray-600); margin-top:16px; line-height:1.6;"></p>
    <div style="margin-top:20px;">
      <a id="qrLink" href="#" target="_blank" style="display:inline-block; padding:12px 24px; background:var(--coral); color:white; border-radius:8px; text-decoration:none; font-weight:600; font-size:14px;"></a>
    </div>
  </div>
</div>
<script>
function openQRModal(type) {
  const modal = document.getElementById('qrModal');
  const img = document.getElementById('qrImage');
  const msg = document.getElementById('qrMessage');
  const link = document.getElementById('qrLink');
  
  if (type === 'whatsapp') {
    img.src = 'images/whatsapp-qr.png';
    msg.innerHTML = '📱 Scan this QR code with WhatsApp to add us.<br><br>Or add us directly: <strong>+86-155-2777-1775</strong><br><br>After adding, feel free to send your inquiry anytime!';
    link.href = 'https://wa.me/8615527771775';
    link.textContent = 'Open WhatsApp Chat';
  } else if (type === 'wechat') {
    img.src = 'images/wechat-qr.png';
    msg.innerHTML = '💬 Scan this QR code with WeChat to add us.<br><br>After adding, feel free to send your inquiry anytime!';
    link.href = 'weixin://';
    link.textContent = 'Open WeChat';
  }
  
  modal.style.display = 'flex';
}
function closeQRModal() {
  document.getElementById('qrModal').style.display = 'none';
}
</script>
<style>
@keyframes bounce {
  0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
  40% { transform: translateY(-8px); }
  60% { transform: translateY(-4px); }
}
</style>
</body>
