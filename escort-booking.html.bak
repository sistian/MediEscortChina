<style> .escort-hero { background: linear-gradient(135deg, var(--navy) 0%, #3D6A7A 100%); color: var(--white); padding: 80px 0 60px; } .escort-hero h1 { font-size: 2.8rem; font-weight: 800; margin-bottom: 12px; } .escort-hero p { font-size: 1.1rem; opacity: 0.85; max-width: 600px; } .booking-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 40px; align-items: start; } .booking-form-card { background: var(--white); border-radius: var(--radius); padding: 40px; box-shadow: var(--shadow-md); border: 1px solid var(--gray-100); } .escort-sidebar { display: flex; flex-direction: column; gap: 20px; } .price-info-card { background: var(--white); border-radius: var(--radius); padding: 28px; box-shadow: var(--shadow-sm); border: 1px solid var(--gray-100); } .price-info-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 16px; color: var(--navy); } .price-info-item { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--gray-100); font-size: 0.85rem; } .escort-option { display: flex; gap: 12px; padding: 16px; border: 2px solid var(--gray-100); border-radius: var(--radius); cursor: pointer; margin-bottom: 12px; } .escort-option.selected { border-color: var(--mint); background: var(--mint-pale); } .escort-option input { display: none; } .escort-option .icon { width: 40px; height: 40px; border-radius: var(--radius-sm); background: var(--mint-pale); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; } .form-group { margin-bottom: 20px; } .form-group label { display: block; font-size: 0.85rem; font-weight: 600; color: var(--navy); margin-bottom: 6px; } .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 12px 16px; border: 1px solid var(--gray-200); border-radius: var(--radius-sm); font-size: 0.9rem; } .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; } .addon-option { display: flex; align-items: center; gap: 10px; padding: 10px 0; cursor: pointer; } .addon-option input { width: 18px; height: 18px; } .total-box { background: var(--navy); color: var(--white); border-radius: var(--radius); padding: 20px; margin: 24px 0; } .total-box .amount { font-size: 1.8rem; font-weight: 800; } .total-box .usd { font-size: 1rem; opacity: 0.85; } .submit-btn { display: block; width: 100%; background: var(--mint); color: var(--navy); padding: 16px; border: none; border-radius: var(--radius-pill); font-size: 1rem; font-weight: 700; cursor: pointer; } .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(43,76,89,0.6); z-index: 9999; align-items: center; justify-content: center; padding: 24px; } .modal-overlay.active { display: flex; } .modal-card { background: var(--white); border-radius: var(--radius); padding: 40px; max-width: 560px; width: 100%; box-shadow: var(--shadow-xl); max-height: 90vh; overflow-y: auto; } .payment-options { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 24px; } .payment-option { text-align: center; padding: 20px; border: 2px solid var(--gray-100); border-radius: var(--radius); } .payment-option img { width: 120px; height: 120px; object-fit: contain; margin: 0 auto 12px; } .pay-btn { display: inline-block; margin-top: 12px; padding: 10px 20px; border-radius: var(--radius-pill); font-size: 0.85rem; font-weight: 600; text-decoration: none; } .paypal-btn { background: #003087; color: white; } .alipay-btn { background: #1677FF; color: white; } .mailto-btn { display: block; width: 100%; background: var(--coral); color: white; padding: 14px; border: none; border-radius: var(--radius-pill); font-size: 0.95rem; font-weight: 600; text-align: center; text-decoration: none; margin-top: 16px; } @media (max-width: 1024px) { .booking-grid { grid-template-columns: 1fr; gap: 24px; } .escort-sidebar { flex-direction: row; flex-wrap: wrap; } .price-info-card { flex: 1; min-width: 280px; } .modal-card { padding: 32px; max-width: 90vw; } } @media (max-width: 768px) { .booking-grid { grid-template-columns: 1fr; } .escort-sidebar { flex-direction: column; } .form-row { grid-template-columns: 1fr; } .payment-options { grid-template-columns: 1fr; } .escort-hero h1 { font-size: 2rem; } .escort-hero { padding: 60px 0 40px; } .booking-form-card { padding: 24px; } .total-box .amount { font-size: 1.5rem; } .modal-card { padding: 24px; } .payment-option img { width: 100px; height: 100px; } } @media (max-width: 480px) { .escort-hero h1 { font-size: 1.5rem; } .booking-form-card { padding: 16px; } .escort-option { padding: 12px; } .escort-option .icon { width: 36px; height: 36px; font-size: 1rem; } .submit-btn { padding: 14px; font-size: 0.95rem; } .total-box { padding: 16px; } .total-box .amount { font-size: 1.3rem; } .modal-card { padding: 20px 16px; } .payment-option { padding: 16px; } .mailto-btn { padding: 12px; font-size: 0.9rem; } } </style>
