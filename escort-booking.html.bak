        <section role="main" class="escort-hero">
          <div class="container">
            <h1>Book Your Medical Escort</h1>
            <p>Professional English-speaking escorts to guide you through every step of your hospital visit in China.</p>
          </div>
        </section>
        <section class="section bg-white">
          <div class="container">
            <div class="booking-grid">
              <div class="booking-form-card">
                <h2 style="font-size:1.5rem;font-weight:700;margin-bottom:8px;color:var(--navy);">Escort Service Booking</h2>
                <p style="color:var(--gray-600);font-size:0.9rem;margin-bottom:32px;">Fill in your details. We'll confirm within 24 hours.</p>
                <form id="escortForm" action="https://formsubmit.co/sistian@qq.com" method="POST" novalidate>\n                  <input type="text" name="website" style="position:absolute;left:-9999px;opacity:0;" tabindex="-1" autocomplete="off">
                  <input type="hidden" name="_next" value="thank-you.html">
                  <input type="hidden" name="_subject" value="🤝 MediEscortChina - New Escort Booking">
                  <input type="hidden" name="_template" value="table">
                  <input type="hidden" name="_captcha" value="false">
                  <input type="text" name="_honey" style="display:none;">
                  <div class="form-group"><label>Select Escort Type <span style="color:var(--danger);">*</span></label><label class="escort-option" data-action="select-escort" data-tier="basic"><input type="radio" name="escortType" value="basic" required onchange="calculateTotal()">
                  <div class="icon">🤝</div>
                  <div style="flex:1;">
                    <h4 style="font-size:0.95rem;font-weight:700;">Basic Escort</h4>
                    <p style="font-size:0.8rem;color:var(--gray-600);">Basic English, hospital navigation, appointment assistance</p>
                    <div style="font-size:0.85rem;color:var(--mint-dark);font-weight:700;margin-top:4px;" id="priceBasic">From ¥300</div>
                  </div>
                  </label><label class="escort-option" data-action="select-escort" data-tier="premium"><input type="radio" name="escortType" value="premium" onchange="calculateTotal()">
                  <div class="icon">🌟</div>
                  <div style="flex:1;">
                    <h4 style="font-size:0.95rem;font-weight:700;">Premium Escort</h4>
                    <p style="font-size:0.8rem;color:var(--gray-600);">Fluent English, medical terminology, cultural bridge</p>
                    <div style="font-size:0.85rem;color:var(--mint-dark);font-weight:700;margin-top:4px;" id="pricePremium">From ¥600</div>
                  </div>
                  </label><label class="escort-option" data-action="select-escort" data-tier="expert"><input type="radio" name="escortType" value="expert" onchange="calculateTotal()">
                  <div class="icon">👨‍⚕️</div>
                  <div style="flex:1;">
                    <h4 style="font-size:0.95rem;font-weight:700;">Expert Escort</h4>
                    <p style="font-size:0.8rem;color:var(--gray-600);">Fluent English + medical background, Tier-1 cities only</p>
                    <div style="font-size:0.85rem;color:var(--mint-dark);font-weight:700;margin-top:4px;" id="priceExpert">From ¥1,000</div>
                  </div>
                  </label></div>
                  <div class="form-group"><label for="escortCity">City <span style="color:var(--danger);">*</span></label><select id="escortCity" name="city" required onchange="calculateTotal()"><option value="" disabled selected>Select your city</option><option disabled style="font-weight:700;color:var(--gray-400);">Tier-1 Cities</option><option value="beijing">Beijing</option><option value="shanghai">Shanghai</option><option value="guangzhou">Guangzhou</option><option value="shenzhen">Shenzhen</option><option disabled style="font-weight:700;color:var(--gray-400);">Tier-2 Cities</option><option value="hangzhou">Hangzhou</option><option value="wuhan">Wuhan</option><option value="chongqing">Chongqing</option><option value="chengdu">Chengdu</option><option disabled style="font-weight:700;color:var(--gray-400);">Other Cities</option><option value="xian">Xi'an</option><option value="nanjing">Nanjing</option><option value="suzhou">Suzhou</option><option value="qingdao">Qingdao</option><option value="xiamen">Xiamen</option><option value="tianjin">Tianjin</option><option value="other">Other (specify in notes)</option></select></div>
                  <div class="form-row">
                    <div class="form-group"><label for="escortDate">Date <span style="color:var(--danger);">*</span></label><input type="date" lang="en" id="escortDate" name="date" required>
                  </div>
                  <div class="form-group"><label for="escortTime">Preferred Time</label><select id="escortTime" name="time"><option value="morning">Morning (8:00-12:00)</option><option value="afternoon">Afternoon (13:00-17:00)</option><option value="evening">Evening (17:00-21:00)</option><option value="full">Full Day</option><option value="flexible">Flexible</option></select></div>
                </div>
                <div class="form-group"><label for="escortDuration">Duration <span style="color:var(--danger);">*</span></label><select id="escortDuration" name="duration" required onchange="calculateTotal()"><option value="half">Half Day (4 hours)</option><option value="full" selected>Full Day (8 hours)</option><option value="multi2">2 Days</option><option value="multi3">3 Days</option><option value="multi5">5 Days</option><option value="custom">Custom (specify in notes)</option></select></div>
                <div class="form-row">
                  <div class="form-group"><label>Full Name <span style="color:var(--danger);">*</span></label><input type="text" name="patientName" id="patientName" required placeholder="John Smith" autocomplete="name">
                </div>
                <div class="form-group"><label>Age</label><input type="number" name="patientAge" id="patientAge" min="1" max="120" placeholder="35">
              </div>
            </div>
            <div class="form-row">
              <div class="form-group"><label>Email <span style="color:var(--danger);">*</span></label><input type="email" name="patientEmail" id="patientEmail" required placeholder="john@example.com" autocomplete="email">
            </div>
            <div class="form-group"><label>Phone /WhatsApp <span style="color:var(--danger);">*</span></label><input type="tel" name="patientPhone" id="patientPhone" required placeholder="+1 234 567 8900" autocomplete="tel">
          </div>
        </div>
        <div class="form-group"><label>Nationality</label><input type="text" id="patientNationality" placeholder="e.g., USA, UK, Australia">
      </div>
      <div class="form-group"><label>Hospital Name (if known)</label><input type="text" name="hospitalName" id="hospitalName" placeholder="e.g., Peking Union Medical College Hospital">
    </div>
    <div class="form-group"><label>Department (if known)</label><input type="text" name="department" id="department" placeholder="e.g., Cardiology, Oncology">
  </div>
  <div class="form-group"><label>Additional Services</label><label class="addon-option"><input type="checkbox" name="addon" value="translate" onchange="calculateTotal()">
  <span style="font-size:0.85rem;color:var(--gray-600);">Medical Document Translation</span><span style="color:var(--mint-dark);font-weight:600;margin-left:auto;font-size:0.8rem;">+¥100</span></label><label class="addon-option"><input type="checkbox" name="addon" value="pickup" onchange="calculateTotal()">
  <span style="font-size:0.85rem;color:var(--gray-600);">Airport/Hotel Pickup & Drop-off</span><span style="color:var(--mint-dark);font-weight:600;margin-left:auto;font-size:0.8rem;">+¥100</span></label><label class="addon-option"><input type="checkbox" name="addon" value="pharmacy" onchange="calculateTotal()">
  <span style="font-size:0.85rem;color:var(--gray-600);">Pharmacy Assistance</span><span style="color:var(--mint-dark);font-weight:600;margin-left:auto;font-size:0.8rem;">+¥50</span></label><label class="addon-option"><input type="checkbox" name="addon" value="report" onchange="calculateTotal()">
  <span style="font-size:0.85rem;color:var(--gray-600);">Written Visit Summary Report</span><span style="color:var(--mint-dark);font-weight:600;margin-left:auto;font-size:0.8rem;">+¥100</span></label></div>
  <div class="form-group"><label>Special Requests /Notes</label><textarea name="specialRequests" id="specialRequests" placeholder="Any specific requirements, mobility needs, language preferences, etc."></textarea></div>
  <div class="total-box">
    <div style="font-size:0.8rem;opacity:0.7;margin-bottom:4px;">Total Amount</div>
    <div class="amount" id="totalRMB">¥0</div>
    <div class="usd" id="totalUSD">≈ $0 USD</div>
    <div style="font-size:0.7rem;opacity:0.6;margin-top:4px;">Exchange rate: 1 USD ≈ 7.2 CNY (approximate)</div>
  </div>
  <p style="font-size:13px; color:var(--gray-500); margin:16px 0;">💡 After submitting, please also check your spam/junk folder. If you don't receive a confirmation within 5 minutes, contact us directly via <a href="https://wa.me/8615527771775">WhatsApp</a>.</p>
                <button type="submit" class="submit-btn">Submit Booking Request</button>
  <p style="font-size:0.75rem;color:var(--gray-400);margin-top:12px;text-align:center;">By submitting, you agree to our <a href="terms.html" style="color:var(--mint-dark);">Terms</a><a href="license.html" style="color:var(--mint);margin-left:8px;">License</a> and <a href="privacy.html" style="color:var(--mint-dark);">Privacy Policy</a>.</p>

              <div style="text-align:center; margin:12px 0 8px; color:var(--gray-400); font-size:13px;">— or —</div>
              <button type="button" class="btn btn-outline" style="width:100%; border:2px solid #25D366; color:#25D366; font-weight:600; margin-bottom:8px;" data-action="send-whatsapp" data-form="escortForm" data-msg="🤝 New Escort Booking">
                💬 Send via WhatsApp
              </button>
            </form>
</div>
<div class="escort-sidebar">
