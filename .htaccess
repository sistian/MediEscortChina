# ============================================================
# MediEscortChina 全站安全 .htaccess 配置（Apache 服务器）
# 将本文件上传至网站根目录（www.MediEscortChina.com）
# 作用：服务器底层安全响应头 + URL重写 + 访问控制
# ============================================================

# ----- 1. 启用 RewriteEngine -----
RewriteEngine On

# ----- 2. HTTP → HTTPS 强制跳转 -----
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://www.MediEscortChina.com/$1 [R=301,L]

# ----- 3. 非 www 域名 → www 强制跳转 -----
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^(.*)$ https://www.MediEscortChina.com/$1 [R=301,L]

# ----- 4. 屏蔽敏感路径（404响应，不暴露存在性）-----
RewriteRule ^(admin|test|backup|config|debug|api|backend|wp-admin|wp-login|phpmyadmin|cgi-bin|shell|cmd|console|manage)/ - [R=404,L,NC]
RewriteRule ^(\.env|\.git|\.svn|\.htaccess|\.htpasswd|config\.json|package\.json|composer\.json) - [R=404,L,NC]

# ----- 5. 禁用目录列表 -----
Options -Indexes

# ----- 6. 禁用服务器签名 -----
ServerSignature Off

# ----- 7. 全站安全响应头 -----
<IfModule mod_headers.c>
    # XSS 防护
    Header always set X-XSS-Protection "1; mode=block"
    
    # 禁止 MIME 类型嗅探
    Header always set X-Content-Type-Options "nosniff"
    
    # 防 iframe 点击劫持
    Header always set X-Frame-Options "DENY"
    
    # Referrer 策略
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # HSTS（强制HTTPS）
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    
    # 权限策略（禁用摄像头/麦克风/定位）
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=()"
    
    # 缓存控制（防止敏感信息泄露）
    <FilesMatch "\.(html|php|htm)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
    
    # 静态资源长期缓存
    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# ----- 8. 限制文件上传类型（如果允许上传）-----
<IfModule mod_security.c>
    SecFilterEngine On
    SecFilterScanPOST On
</IfModule>

# ----- 9. 禁用危险 HTTP 方法 -----
<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_METHOD} ^(TRACE|TRACK|OPTIONS|HEAD)
    RewriteRule .* - [F]
</IfModule>

# ----- 10. 保护 .git 等隐藏目录 -----
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# ----- 11. PHP 安全设置（如服务器支持 PHP）-----
<IfModule mod_php.c>
    php_flag display_errors off
    php_flag log_errors on
    php_value error_log /var/log/php_errors.log
</IfModule>

# ----- 12. 防盗链（可选：保护图片资源）-----
# <IfModule mod_rewrite.c>
#     RewriteCond %{HTTP_REFERER} !^$
#     RewriteCond %{HTTP_REFERER} !^https?://(www\.)?MediEscortChina\.com [NC]
#     RewriteRule \.(jpg|jpeg|png|gif|webp)$ - [F,NC]
# </IfModule>
